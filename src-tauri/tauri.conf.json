{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PufferBlow",
  "version": "1.0.0",
  "identifier": "space.pufferblow.desktop.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PufferBlow",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "Decentralized chat client",
    "longDescription": "PufferBlow desktop client powered by Tauri."
  }
}
